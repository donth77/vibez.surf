# ---------------------------------------------------------------------------
# Client-side (baked into the Vite bundle at build time)
# --------------------------------------------------------------------------
# Suno share-link resolver Worker — converts suno.com/s/<code> to
# {uuid, title, audioUrl}. See: workers/suno-share-resolver/ for deploy steps.
# Trailing slash optional.
VITE_SUNO_RESOLVER=https://your-suno-resolver.example.workers.dev/

# Suno generation proxy — primary URL. Each
# visitor supplies their own Suno cookie via the settings modal; this
# env var just points the client at the proxy to hit.
VITE_SUNO_API_URL=https://your-suno-proxy.example.com

# Fallback proxy, tried on 5xx or timeout from the primary. Useful when
# the primary is on a free serverless platform with short timeouts
# Leave blank to disable the fallback.
VITE_SUNO_API_URL_FALLBACK=https://your-suno-proxy-fallback.example.com


# ---------------------------------------------------------------------------
# Deploy tooling (NOT exposed to the browser)
# ---------------------------------------------------------------------------
# Used by `wrangler deploy` in workers/suno-share-resolver — skip the OAuth
# login flow by setting this instead. Create at:
#   https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit Cloudflare Workers" template.
CLOUDFLARE_API_TOKEN=
